--------------------- Actions class

Actions action = new Actions(driver);

Hover the Mouse - actions.moveToElement(WebElement).build().perform();
Drag and Drop   - actions.dragAndDrop(from1, to1).build().perform();
Scroll          - actions.pause(Duration.ofMillis(4000)).scrollByAmount(300,300).build().perform();
Keyboard Key    - actions.keyDown(Keys.CONTROL).click(signIN).keyUp(Keys.CONTROL).build().perform()

